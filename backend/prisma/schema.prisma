// Smart Finance SaaS — Prisma Schema
// Single source of truth (อ้างอิง docs/02-database-schema.md)
// money = BigInt (สตางค์), public_id = uuid, soft delete = deleted_at

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────── Enums (native) ───────────────────────────

enum SystemRole {
  user
  admin
}

enum WorkspaceType {
  personal
  business
}

enum MembershipRole {
  owner
  admin
  member
}

enum WalletType {
  cash
  bank
  ewallet
  other
}

enum CategoryType {
  income
  expense
}

enum TransactionType {
  income
  expense
  transfer
}

enum PlanCode {
  free
  pro
  business
  premium
}

enum SubscriptionStatus {
  active
  trialing
  past_due
  canceled
  expired
}

enum PaymentMethod {
  promptpay
  manual
}

enum PaymentStatus {
  pending
  approved
  rejected
}

enum SupportType {
  feedback
  contact
}

enum SupportStatus {
  open
  closed
}

enum InvitationStatus {
  pending
  accepted
  revoked
  expired
}

// ─────────────────────────── Models ───────────────────────────

model User {
  id              BigInt      @id @default(autoincrement())
  publicId        String      @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("public_id")
  name            String      @db.VarChar(120)
  email           String      @unique @db.VarChar(255)
  // nullable — ผู้ใช้ที่สมัครผ่าน OAuth (Google) ไม่มีรหัสผ่าน
  password        String?     @db.VarChar(255)
  // Google OAuth: subject id (sub) — unique ต่อบัญชี Google; null = ไม่ได้ผูก Google
  googleId        String?     @unique @map("google_id") @db.VarChar(64)
  avatarUrl       String?     @map("avatar_url") @db.VarChar(512)
  systemRole      SystemRole  @default(user) @map("system_role")
  emailVerifiedAt DateTime?   @map("email_verified_at") @db.Timestamptz(6)
  lastLoginAt     DateTime?   @map("last_login_at") @db.Timestamptz(6)
  suspendedAt     DateTime?   @map("suspended_at") @db.Timestamptz(6)

  // brute-force lockout: นับ login ที่ผิด + ล็อกชั่วคราวเมื่อถึงเกณฑ์
  failedLoginCount Int       @default(0) @map("failed_login_count")
  lockedUntil      DateTime? @map("locked_until") @db.Timestamptz(6)

  lastActiveWorkspaceId BigInt?    @map("last_active_workspace_id")
  lastActiveWorkspace   Workspace? @relation("UserLastActiveWorkspace", fields: [lastActiveWorkspaceId], references: [id], onDelete: SetNull)

  ownedWorkspaces  Workspace[]      @relation("WorkspaceOwner")
  memberships      Membership[]
  transactions     Transaction[]    @relation("TransactionCreatedBy")
  refreshTokens    RefreshToken[]
  auditLogs        AdminAuditLog[]  @relation("AuditActor")
  reviewedPayments Payment[]        @relation("PaymentReviewer")
  supportTickets   SupportTicket[]
  sentInvitations  WorkspaceInvitation[] @relation("InvitationInviter")
  activityLogs     ActivityLog[]    @relation("ActivityActor")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@map("users")
}

model Workspace {
  id           BigInt        @id @default(autoincrement())
  publicId     String        @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("public_id")
  ownerId      BigInt        @map("owner_id")
  owner        User          @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  name         String        @db.VarChar(120)
  type         WorkspaceType
  baseCurrency String        @default("THB") @map("base_currency") @db.Char(3)
  settings     Json          @default("{}") @db.JsonB
  suspendedAt  DateTime?     @map("suspended_at") @db.Timestamptz(6)

  memberships   Membership[]
  wallets       Wallet[]
  categories    Category[]
  transactions  Transaction[]
  payments      Payment[]
  subscriptions Subscription[]
  invitations   WorkspaceInvitation[]
  activityLogs  ActivityLog[]
  activeForUsers User[]       @relation("UserLastActiveWorkspace")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@index([ownerId])
  @@map("workspaces")
}

model Membership {
  id          BigInt         @id @default(autoincrement())
  workspaceId BigInt         @map("workspace_id")
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      BigInt         @map("user_id")
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        MembershipRole

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@map("memberships")
}

model Wallet {
  id             BigInt     @id @default(autoincrement())
  publicId       String     @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("public_id")
  workspaceId    BigInt     @map("workspace_id")
  workspace      Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name           String     @db.VarChar(120)
  type           WalletType
  currency       String     @default("THB") @db.Char(3)
  initialBalance BigInt     @default(0) @map("initial_balance")
  color          String?    @db.VarChar(9)
  icon           String?    @db.VarChar(40)
  isArchived     Boolean    @default(false) @map("is_archived")

  // ความสัมพันธ์ทั้งสองทิศของ transaction (source + destination)
  sourceTransactions      Transaction[] @relation("TxSourceWallet")
  destinationTransactions Transaction[] @relation("TxDestinationWallet")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@index([workspaceId])
  @@map("wallets")
}

model Category {
  id          BigInt       @id @default(autoincrement())
  publicId    String       @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("public_id")
  workspaceId BigInt?      @map("workspace_id") // NULL = system default
  workspace   Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String       @db.VarChar(80)
  type        CategoryType
  icon        String?      @db.VarChar(40)
  color       String?      @db.VarChar(9)
  isSystem    Boolean      @default(false) @map("is_system")
  sortOrder   Int          @default(0) @map("sort_order")

  transactions Transaction[]

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@index([workspaceId, type])
  @@map("categories")
}

model Transaction {
  id          BigInt          @id @default(autoincrement())
  publicId    String          @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("public_id")
  workspaceId BigInt          @map("workspace_id")
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  walletId    BigInt          @map("wallet_id")
  wallet      Wallet          @relation("TxSourceWallet", fields: [walletId], references: [id], onDelete: Restrict)

  destinationWalletId BigInt? @map("destination_wallet_id") // transfer only
  destinationWallet   Wallet? @relation("TxDestinationWallet", fields: [destinationWalletId], references: [id], onDelete: Restrict)

  categoryId  BigInt?         @map("category_id") // NULL on transfer
  category    Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  createdById BigInt          @map("created_by")
  createdBy   User            @relation("TransactionCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  type            TransactionType
  amount          BigInt          // สตางค์, CHECK (amount > 0) — ดู migration SQL
  currency        String          @default("THB") @db.Char(3)
  note            String?         @db.Text
  transactionDate DateTime        @map("transaction_date") @db.Date

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@index([workspaceId, transactionDate(sort: Desc)])
  @@index([workspaceId, walletId])
  @@index([workspaceId, categoryId])
  @@index([workspaceId, type])
  @@index([destinationWalletId])
  @@map("transactions")
}

model Plan {
  id                    BigInt   @id @default(autoincrement())
  code                  PlanCode @unique
  name                  String   @db.VarChar(60)
  price                 BigInt   @default(0) // สตางค์/เดือน
  maxWorkspaces         Int?     @map("max_workspaces")
  maxWallets            Int?     @map("max_wallets")
  maxTransactionsMonth  Int?     @map("max_transactions_month")
  maxMembers            Int?     @map("max_members") // จำนวนสมาชิกต่อ workspace (business); null = ไม่จำกัด
  features              Json     @default("{}") @db.JsonB
  isActive              Boolean  @default(true) @map("is_active")

  subscriptions Subscription[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("plans")
}

model Subscription {
  id          BigInt             @id @default(autoincrement())
  publicId    String             @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("public_id")
  workspaceId BigInt             @map("workspace_id")
  workspace   Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  planId      BigInt             @map("plan_id")
  plan        Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)
  status      SubscriptionStatus

  startedAt          DateTime  @map("started_at") @db.Timestamptz(6)
  currentPeriodStart DateTime  @map("current_period_start") @db.Timestamptz(6)
  currentPeriodEnd   DateTime  @map("current_period_end") @db.Timestamptz(6)
  canceledAt         DateTime? @map("canceled_at") @db.Timestamptz(6)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // partial unique (1 active/workspace) → migration SQL
  @@index([workspaceId])
  @@map("subscriptions")
}

// ─────────────── Business workspace: team + activity ───────────────

// คำเชิญสมาชิกเข้า workspace (business) ทางอีเมล — รับด้วย token
model WorkspaceInvitation {
  id          BigInt           @id @default(autoincrement())
  publicId    String           @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("public_id")
  workspaceId BigInt           @map("workspace_id")
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  email       String           @db.VarChar(255)
  role        MembershipRole // admin (Manager) | member (Staff) — เชิญ owner ไม่ได้
  tokenHash   String           @unique @map("token_hash") @db.VarChar(255) // SHA-256 hex (ไม่เก็บ plain)
  status      InvitationStatus @default(pending)
  invitedById BigInt           @map("invited_by_id")
  invitedBy   User             @relation("InvitationInviter", fields: [invitedById], references: [id], onDelete: Cascade)
  expiresAt   DateTime         @map("expires_at") @db.Timestamptz(6)
  acceptedAt  DateTime?        @map("accepted_at") @db.Timestamptz(6)
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([workspaceId])
  @@index([email])
  @@map("workspace_invitations")
}

// บันทึกกิจกรรมของสมาชิกใน workspace (ใคร สร้าง/แก้/ลบ รายการ) — ต่างจาก AdminAuditLog ฝั่ง back-office
model ActivityLog {
  id          BigInt    @id @default(autoincrement())
  workspaceId BigInt    @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actorId     BigInt?   @map("actor_id")
  actor       User?     @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)
  action      String    @db.VarChar(80) // transaction.create, transaction.update, member.invite ...
  targetType  String?   @map("target_type") @db.VarChar(40)
  targetId    String?   @map("target_id") @db.VarChar(80)
  metadata    Json      @default("{}") @db.JsonB
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([actorId])
  @@map("activity_logs")
}

// ─────────────── Auth infra (รายละเอียดเต็มใน Step 5) ───────────────

model RefreshToken {
  id        BigInt    @id @default(autoincrement())
  userId    BigInt    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @map("token_hash") @db.VarChar(255) // SHA-256 hex (ไม่เก็บ plain)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        BigInt   @id @default(autoincrement())
  email     String   @db.VarChar(255)
  tokenHash String   @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([email])
  @@map("password_reset_tokens")
}

// ─────────────── Admin / SaaS back-office (Step 9) ───────────────

model AdminAuditLog {
  id         BigInt   @id @default(autoincrement())
  actorId    BigInt?  @map("actor_id")
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action     String   @db.VarChar(80) // admin.login, user.suspend, payment.approve ...
  targetType String?  @map("target_type") @db.VarChar(40)
  targetId   String?  @map("target_id") @db.VarChar(80)
  metadata   Json     @default("{}") @db.JsonB
  ip         String?  @db.VarChar(64)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([actorId])
  @@index([createdAt])
  @@map("admin_audit_logs")
}

model Payment {
  id           BigInt        @id @default(autoincrement())
  publicId     String        @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("public_id")
  workspaceId  BigInt        @map("workspace_id")
  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  planCode     PlanCode      @map("plan_code")
  amount       BigInt // satang
  method       PaymentMethod @default(promptpay)
  status       PaymentStatus @default(pending)
  reference    String?       @db.VarChar(120) // เลขอ้างอิง/สลิป
  reviewedById BigInt?       @map("reviewed_by_id")
  reviewedBy   User?         @relation("PaymentReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt   DateTime?     @map("reviewed_at") @db.Timestamptz(6)
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([status])
  @@index([workspaceId])
  @@map("payments")
}

model SupportTicket {
  id        BigInt        @id @default(autoincrement())
  publicId  String        @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("public_id")
  userId    BigInt?       @map("user_id")
  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  email     String        @db.VarChar(255)
  type      SupportType   @default(contact)
  subject   String        @db.VarChar(160)
  message   String        @db.Text
  status    SupportStatus @default(open)
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([status])
  @@index([type])
  @@map("support_tickets")
}

model AppSetting {
  id        BigInt   @id @default(autoincrement())
  key       String   @unique @db.VarChar(80)
  value     Json     @default("{}") @db.JsonB
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("app_settings")
}

// ───────────────────────────────────────────────────────────────
// Raw-SQL ที่ต้องเพิ่มเองใน migration (Prisma ยังไม่รองรับตรง):
//   • CHECK (amount > 0)
//   • CHECK transfer: type='transfer' ⇒ destination_wallet_id NOT NULL
//        AND category_id IS NULL AND destination_wallet_id <> wallet_id
//   • CHECK income/expense ⇒ destination_wallet_id IS NULL
//   • Partial unique: CREATE UNIQUE INDEX ... ON subscriptions(workspace_id)
//        WHERE status = 'active'
//   • Partial unique email: ON users(email) WHERE deleted_at IS NULL
//   • CREATE EXTENSION IF NOT EXISTS pgcrypto;
// ───────────────────────────────────────────────────────────────
