# ============================================================
#  Smart Finance SaaS — BACKEND production env (Supabase + Railway)
#  คัดลอกค่าจริงไปตั้งใน Railway → Variables (อย่า commit ค่าจริง)
# ============================================================

# ---- App ----
NODE_ENV=production
PORT=8000
API_PREFIX=api/v1

# ---- CORS / origins (ต้องเป็น domain จริง ห้าม localhost) ----
# tenant frontend (Vercel)
FRONTEND_URL=https://app.your-domain.com
# admin portal (ถ้าแยก domain; เว้นว่างได้ถ้าใช้ path /admin เดียวกัน)
ADMIN_URL=https://admin.your-domain.com
# override allowlist ถ้าต้องการ (คั่น comma); เว้นว่าง = FRONTEND_URL + ADMIN_URL
CORS_ORIGIN=

# ---- Supabase PostgreSQL ----
# DATABASE_URL = pooled (PgBouncer, transaction mode, พอร์ต 6543) สำหรับ runtime
#   ต้องมี ?pgbouncer=true&connection_limit=1 และ sslmode=require
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
# DIRECT_URL = direct/session (พอร์ต 5432) สำหรับ prisma migrate deploy เท่านั้น
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require"

# ---- JWT (สร้างใหม่ทั้งหมด ห้ามใช้ค่า dev — ยาว ≥ 32 ตัว) ----
# สร้างด้วย: openssl rand -base64 48
JWT_ACCESS_SECRET=__GENERATE_STRONG_SECRET__
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=__GENERATE_STRONG_SECRET__
JWT_REFRESH_TTL=30d

# ---- Admin auth (namespace แยก — ต้องตั้ง ไม่งั้น boot จะ fail) ----
JWT_ADMIN_ACCESS_SECRET=__GENERATE_STRONG_SECRET__
JWT_ADMIN_ACCESS_TTL=15m
JWT_ADMIN_REFRESH_SECRET=__GENERATE_STRONG_SECRET__
JWT_ADMIN_REFRESH_TTL=7d

# ---- Cookies (cross-site: Vercel ↔ Railway) ----
# production บังคับ true (env.validation จะ throw ถ้าไม่ true)
COOKIE_SECURE=true
# คนละ domain → ต้อง none; ถ้า subdomain เดียวกันใช้ lax ได้
COOKIE_SAMESITE=none
# ตั้งเฉพาะกรณี share cookie ข้าม subdomain เช่น .your-domain.com (เว้นว่าง = host เดียว)
COOKIE_DOMAIN=

# ---- Rate limit ----
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# ---- Mail ----
MAIL_FROM="Smart Finance <noreply@your-domain.com>"
