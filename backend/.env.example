# ---- App ----
NODE_ENV=development
PORT=8000
API_PREFIX=api/v1
# tenant app origin
FRONTEND_URL=http://localhost:3000
# admin portal origin (ถ้า deploy แยก domain); ว่างได้ใน dev (ใช้ path /admin เดียวกัน)
ADMIN_URL=
# override CORS allowlist (คั่นด้วย comma); ว่าง = FRONTEND_URL + ADMIN_URL
CORS_ORIGIN=

# ---- Database (PostgreSQL / Supabase) ----
# Pooled connection (PgBouncer) สำหรับ runtime
DATABASE_URL="postgresql://postgres:password@localhost:5432/smart_finance?schema=public"
# Direct connection สำหรับ prisma migrate
DIRECT_URL="postgresql://postgres:password@localhost:5432/smart_finance?schema=public"

# ---- JWT ----
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_TTL=30d
# ตั้ง true ใน production (HTTPS)
COOKIE_SECURE=false
# 'lax' = same-site (custom domain); 'none' = cross-site (เช่น vercel.app ↔ railway.app, ต้อง COOKIE_SECURE=true)
COOKIE_SAMESITE=lax
# parent domain สำหรับ share cookie ข้าม subdomain (เช่น .smartfinance.app); ว่าง = host เดียว
COOKIE_DOMAIN=

# ---- Admin auth (separate namespace) ----
JWT_ADMIN_ACCESS_SECRET=change-me-admin-access
JWT_ADMIN_REFRESH_SECRET=change-me-admin-refresh
JWT_ADMIN_ACCESS_TTL=15m
JWT_ADMIN_REFRESH_TTL=7d

# ---- Throttle (rate limit) ----
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# ---- Mail (forgot password) — Step 5 ----
MAIL_FROM="Smart Finance <noreply@smartfinance.app>"
