# ---- App ----
NODE_ENV=development
PORT=8000
API_PREFIX=api/v1
# tenant app origin
FRONTEND_URL=http://localhost:3000
# admin portal origin (ถ้า deploy แยก domain); ว่างได้ใน dev (ใช้ path /admin เดียวกัน)
ADMIN_URL=
# override CORS allowlist (คั่นด้วย comma); ว่าง = FRONTEND_URL + ADMIN_URL
CORS_ORIGIN=

# ---- Database (PostgreSQL / Supabase) ----
# Pooled connection (PgBouncer) สำหรับ runtime
DATABASE_URL="postgresql://postgres:password@localhost:5432/smart_finance?schema=public"
# Direct connection สำหรับ prisma migrate
DIRECT_URL="postgresql://postgres:password@localhost:5432/smart_finance?schema=public"

# ---- JWT ----
# secret ต้องยาว ≥ 32 ตัวอักษร (256-bit) — แนะนำ `openssl rand -hex 32`
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-xxxxx
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-xxxx
JWT_REFRESH_TTL=30d
# ตั้ง true ใน production (HTTPS)
COOKIE_SECURE=false
# 'lax' = same-site (custom domain); 'none' = cross-site (เช่น vercel.app ↔ railway.app, ต้อง COOKIE_SECURE=true)
COOKIE_SAMESITE=lax
# parent domain สำหรับ share cookie ข้าม subdomain (เช่น .smartfinance.app); ว่าง = host เดียว
COOKIE_DOMAIN=

# ---- Admin auth (separate namespace) ----
# secret ต้องยาว ≥ 32 ตัวอักษรเช่นกัน
JWT_ADMIN_ACCESS_SECRET=change-me-admin-access-min-32-chars-xxxxx
JWT_ADMIN_REFRESH_SECRET=change-me-admin-refresh-min-32-chars-xxx
JWT_ADMIN_ACCESS_TTL=15m
JWT_ADMIN_REFRESH_TTL=7d

# ---- Throttle (rate limit) ----
THROTTLE_TTL=60
THROTTLE_LIMIT=120
# ตั้งเมื่อสเกลหลาย instance → rate limit แชร์ข้าม pod (เช่น Railway/Upstash Redis)
# ว่าง = ใช้ in-memory (เครื่องเดียว)
REDIS_URL=

# ---- Google OAuth ----
# จาก Google Cloud Console → Credentials → OAuth client ID (Web application)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# ต้องตรงกับ Authorized redirect URI ใน Google Console เป๊ะ
GOOGLE_CALLBACK_URL=http://localhost:8000/api/v1/auth/google/callback

# ---- Business reports: PDF font ----
# path ไป TTF ฟอนต์ไทย (เช่น NotoSansThai) เพื่อให้ PDF export แสดงภาษาไทยถูกต้อง
# ว่าง = ใช้ Helvetica (หัวข้ออังกฤษอ่านได้ แต่ชื่อหมวดภาษาไทยจะเพี้ยน)
PDF_FONT_PATH=

# ---- Mail (forgot password) — Step 5 ----
MAIL_FROM="Smart Finance <noreply@smartfinance.app>"
